# Google Maps API Key
MAPS_API_KEY=your_google_maps_api_key_here

# Published Google Sheets CSV URL
# Go to File > Share > Publish to web, choose CSV format and copy the URL
CSV_URL=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?output=csv

# Set to true only during local development – never in production
FLASK_DEBUG=False
